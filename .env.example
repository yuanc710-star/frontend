# Backend-for-frontend (BFF) origin that owns Google sign-in login/callback + the API.
# Server-side: used by next.config.ts rewrites to proxy /auth/* and /api/*.
BFF_URL=http://localhost:4000

# Client-side: where the app sends the browser to start the Google sign-in flow.
# Leave empty to use same-origin (recommended when the rewrites above are set).
NEXT_PUBLIC_BFF_URL=
